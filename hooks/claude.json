{
  "skipDangerousModePermissionPrompt": true,
  "editorMode": "normal",
  "_comment": "Deepwork hooks baseline, v5.0.0 — aligns with ~/.claude-accounts/*/hooks/. Never use 'gc' (gas-city) commands — mandate: use 'gt' only. See knowledge/hooks-reference.md.",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "export PATH=\"$HOME/go/bin:$HOME/.local/bin:$PATH\" && /home/pratham2/.claude/hooks/memory-recall-session-start.sh"
          },
          {
            "type": "command",
            "command": "export PATH=\"$HOME/go/bin:$HOME/.local/bin:$PATH\" && gt prime --hook"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "export PATH=\"$HOME/go/bin:$HOME/.local/bin:$PATH\" && /home/pratham2/gt/deepwork_intelligence/agents/handoff/precompact_hook.sh"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "export PATH=\"$HOME/go/bin:$HOME/.local/bin:$PATH\" && timeout 5 gt mail check --inject"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "/home/pratham2/.claude/hooks/readme-guard.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/home/pratham2/.claude/hooks/post-close-emit.sh"
          },
          {
            "type": "command",
            "command": "/home/pratham2/.claude/hooks/epic-mountain-guard.sh"
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "/home/pratham2/.claude/hooks/memory-mirror.sh"
          }
        ]
      }
    ]
  }
}
