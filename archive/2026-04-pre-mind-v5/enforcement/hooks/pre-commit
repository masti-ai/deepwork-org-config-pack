#!/bin/bash
# pre-commit hook — Prevent committing secrets and large files
# Installed by: enforcement/install.sh

# Block secrets
SECRETS_PATTERN='(AWS_SECRET|PRIVATE_KEY|password\s*=\s*["\x27][^\s]+|sk-[a-zA-Z0-9]{20,}|ghp_[a-zA-Z0-9]{36}|gho_[a-zA-Z0-9]{36})'
STAGED=$(git diff --cached --name-only)

for file in $STAGED; do
  # Skip binary files and lock files
  [[ "$file" =~ \.(lock|png|jpg|jpeg|gif|ico|woff|ttf|pdf|zip)$ ]] && continue
  [[ "$file" =~ ^node_modules/ ]] && continue

  # Check for secrets in staged content
  if git diff --cached -- "$file" | grep -qEi "$SECRETS_PATTERN" 2>/dev/null; then
    echo ""
    echo "ERROR: Possible secret detected in $file"
    echo "Review the staged changes and remove any credentials."
    echo ""
    echo "If this is a false positive, commit with: git commit --no-verify"
    echo ""
    exit 1
  fi
done

# Block large files (>5MB)
for file in $STAGED; do
  size=$(git cat-file -s :"$file" 2>/dev/null || echo 0)
  if [ "$size" -gt 5242880 ]; then
    echo ""
    echo "ERROR: $file is $(($size / 1048576))MB — exceeds 5MB limit."
    echo "Use Git LFS for large files: git lfs track '$file'"
    echo ""
    exit 1
  fi
done

# Block .env files
for file in $STAGED; do
  if [[ "$file" =~ (^|/)\.env($|\.) ]] && [[ ! "$file" =~ \.example$ ]]; then
    echo ""
    echo "ERROR: Attempting to commit $file — .env files must not be committed."
    echo "Add it to .gitignore and use .env.example instead."
    echo ""
    exit 1
  fi
done

exit 0
