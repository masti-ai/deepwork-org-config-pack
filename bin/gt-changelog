#!/bin/bash
# gt-changelog — Quick changelog entry from anywhere
#
# Usage:
#   gt-changelog "Fixed auth bug in project-alpha"
#   gt-changelog --type fix --rig project_alpha "Fixed auth bug"
#   gt-changelog --type milestone --rig town "Wasteland v1 launched"
#   gt-changelog --list          # Show recent entries
#   gt-changelog --edit          # Open current month in editor

set -uo pipefail

GT_ROOT="${GT_ROOT:-$HOME/gt}"
CL_DIR="$GT_ROOT/mayor/changelog"
APPEND="$CL_DIR/append.sh"
MONTH_FILE="$CL_DIR/$(date +%Y-%m).md"

# Defaults
TYPE="fix"
RIGS="town"

show_help() {
  echo "Usage: gt-changelog [options] <message>"
  echo ""
  echo "Options:"
  echo "  --type TYPE    decision|deploy|fix|incident|milestone|infra (default: fix)"
  echo "  --rig RIG      Rig name or 'town' (default: town)"
  echo "  --list         Show recent changelog entries"
  echo "  --edit         Open current month file in editor"
  echo "  -h, --help     Show this help"
  echo ""
  echo "Examples:"
  echo "  gt-changelog 'Fixed CORS issue in backend'"
  echo "  gt-changelog --type milestone --rig project_alpha 'Dashboard v2 shipped'"
  echo "  gt-changelog --type incident --rig town 'Dolt crashed, restarted'"
}

# Parse args
POSITIONAL=()
while [[ $# -gt 0 ]]; do
  case $1 in
    --type) TYPE="$2"; shift 2 ;;
    --rig) RIGS="$2"; shift 2 ;;
    --list)
      echo "=== Recent Changelog ==="
      [ -f "$MONTH_FILE" ] && head -40 "$MONTH_FILE" || echo "(no entries this month)"
      exit 0 ;;
    --edit)
      ${EDITOR:-vim} "$MONTH_FILE"
      exit 0 ;;
    -h|--help) show_help; exit 0 ;;
    *) POSITIONAL+=("$1"); shift ;;
  esac
done

MESSAGE="${POSITIONAL[*]:-}"
[ -z "$MESSAGE" ] && { show_help; exit 1; }

bash "$APPEND" "$TYPE" "$RIGS" "$MESSAGE" "$MESSAGE"
