# Mesh Configuration Template
# 
# This template configures mesh communication for Gas Town.
# Compatible with debug mine for troubleshooting.
#
# Usage:
#   1. Copy to ~/.config/gt/mesh.yaml
#   2. Fill in your rig paths
#   3. Run `gt mesh init` to validate

mesh:
  version: "4.0.0"
  town_id: "{{ .TownId }}"
  
  # ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  # DEBUG MINE COMPATIBILITY
  # ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  # 
  # Set debug: true to enable verbose logging for troubleshooting
  # Debug output goes to: ~/.gt/logs/mesh-debug.log
  
  debug: {{ .Debug | default "false" }}
  debug_level: {{ .DebugLevel | default "info" }}  # debug, info, warn, error
  
  # Debug mine specific settings
  debug_mine:
    enabled: {{ .DebugMineEnabled | default "false" }}
    capture_nudges: true
    capture_mail: true
    log_retention: "7d"
    
  # ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  # RIGS
  # ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  
  rigs:
    {{ range .Rigs }}
    - name: "{{ .Name }}"
      path: "{{ .Path }}"
      repo: "{{ .Repo }}"
      priority: {{ .Priority | default "1" }}
      
      # Wasteland integration
      wasteland:
        auto_sync: {{ .WastelandAutoSync | default "true" }}
        min_priority: {{ .WastelandMinPriority | default "1" }}
        github_repo: "{{ .GithubRepo }}"
    {{ end }}
  
  # ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  # GT MODE
  # ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  
  mode: {{ .Mode | default "balanced" }}  # eco, balanced, turbo, maintenance
  
  # Mode overrides
  mode_config:
    eco:
      agent_pool_max: 2
      scheduler_interval: "5m"
    balanced:
      agent_pool_max: 5
      scheduler_interval: "30s"
    turbo:
      agent_pool_max: 10
      scheduler_interval: "10s"
  
  # ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  # COMMUNICATION
  # ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  
  nudge:
    enabled: true
    timeout: "30s"
    retry: 3
    
  mail:
    enabled: true
    retention: "30d"
    
  # ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  # DI INTEGRATION
  # ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  
  di:
    enabled: {{ .DiEnabled | default "true" }}
    templates_dir: "{{ .DiTemplatesDir | default "~/gt/deepwork_intelligence/templates" }}"
    default_model: "{{ .DiDefaultModel | default "anthropic/claude-sonnet-4" }}"
    
    # DI MCP endpoints
    mcp:
      host: "{{ .DiMcpHost | default "localhost" }}"
      port: {{ .DiMcpPort | default "3000" }}
      
  # ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  # HOOKS
  # ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  
  hooks:
    sync_on_start: true
    overlays:
      - base
      - {{ .Role }}  # Role-specific overlay
      
  # ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  # SMART CRON
  # ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  
  cron:
    retry_strategy: "exponential"  # fixed, exponential, linear
    retry_max: 3
    mode_aware: true
    
  # ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  # MONITORING
  # ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  
  monitoring:
    enabled: {{ .MonitoringEnabled | default "true" }}
    
    # GT Monitor integration
    gt_monitor:
      host: "{{ .GtMonitorHost | default "localhost" }}"
      port: {{ .GtMonitorPort | default "9090" }}
      
    # Alert thresholds
    alerts:
      unhealthy_agent: "5m"
      stuck_bead: "30m"
      high_cost: "100"
      
  # ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  # DEBUG MINE TRIGGERS
  # ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  
  debug_triggers:
    # Auto-enable debug when these conditions are met
    - condition: "estop_active"
      action: "enable_debug"
      duration: "1h"
      
    - condition: "consecutive_failures > 3"
      action: "capture_diagnostics"
      notify: mayor
      
    - condition: "agent_unresponsive > 5m"
      action: "force_kill_and_debug"
      notify: deacon
